# Supabase connection (use the service role key on the backend — never the anon key)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED: server will refuse to start if this is missing
JWT_SECRET=replace-with-a-long-random-hex-string

# Comma-separated list of allowed CORS origins (exact match)
CORS_ORIGINS=https://your-app.vercel.app

# Admin seed account (used only during first-run database initialisation)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-on-first-login

# Resend — invitation email for new admins (https://resend.com)
# If unset: new rows keep email_verified_at NULL (UI shows "Pending"), but login is still allowed
# so you can test without email. If set: login is blocked until they open the verify link in email.
RESEND_API_KEY=
RESEND_FROM_EMAIL="MISD Help Desk <onboarding@resend.dev>"

# SMTP (admin invites only) — optional. If set, invite emails will be sent via SMTP instead of the Resend HTTP API.
# Commonly used with Resend SMTP: host smtp.resend.com port 587
ADMIN_INVITE_SMTP_HOST=
ADMIN_INVITE_SMTP_PORT=587
ADMIN_INVITE_SMTP_SECURE=false
ADMIN_INVITE_SMTP_USER=
ADMIN_INVITE_SMTP_PASS=
ADMIN_INVITE_FROM_EMAIL="MISD Help Desk <onboarding@resend.dev>"

# Used in the verification link (your Vite / production site). No trailing slash.
PUBLIC_BASE_URL=http://localhost:5173

# Runtime environment
NODE_ENV=production
