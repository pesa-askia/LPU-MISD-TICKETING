# Runtime
NODE_ENV=production
PORT=5000

# Supabase connection
# Use the service role key on the backend. Never expose it in frontend env files.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-hex-string

# Public app/backend URLs
# CORS_ORIGINS accepts comma-separated exact origins.
CORS_ORIGINS=https://your-app.vercel.app
PUBLIC_BASE_URL=https://your-app.vercel.app

# Student magic-link domain allowlist
MAGIC_LINK_ALLOWED_DOMAINS=@lpulaguna.edu.ph,@lpusc.edu.ph

# Admin seed account, used during first-run database initialization
ADMIN_SEED_FULL_NAME=System Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-now

# Admin invitation email via Resend
# When RESEND_API_KEY is set, admin email verification is enforced.
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL="LPU MISD Help Desk <noreply@your-domain.example>"

# AI/chatbot configuration
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Optional chatbot cooldown tuning
# CHATBOT_MIN_MESSAGE_GAP_MS=2000
# CHATBOT_LIMIT_WINDOW_MS=86400000
# CHATBOT_COOLDOWNS_SEC=60,300,900
# CHATBOT_COOLDOWN_BASE_MS=45000
# CHATBOT_COOLDOWN_GROWTH=2.35
# CHATBOT_COOLDOWN_STEPS=6
# CHATBOT_COOLDOWN_MAX_MS=1800000
