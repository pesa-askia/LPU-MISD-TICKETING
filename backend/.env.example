# Supabase connection (use the service role key on the backend — never the anon key)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED: server will refuse to start if this is missing
JWT_SECRET=replace-with-a-long-random-hex-string

# Comma-separated list of allowed CORS origins (exact match)
CORS_ORIGINS=https://your-app.vercel.app

# Admin seed account (used only during first-run database initialisation)
ADMIN_SEED_FULL_NAME=System Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-on

# Runtime environment
NODE_ENV=production

# Chatbot configuration
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
# Min ms between *successful* messages (0 to disable; violations only if user sends while cooldown is active)
# CHATBOT_MIN_MESSAGE_GAP_MS=2000
# Rolling window; violation count resets when this elapses
# CHATBOT_LIMIT_WINDOW_MS=86400000
# Optional explicit penalty tiers in seconds (1st, 2nd, 3rd violation…)
# CHATBOT_COOLDOWNS_SEC=60,300,900